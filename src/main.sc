import com.justai.jaicf.builder.Scenario

object MainScenario : Scenario() {
    init {
        // Стейт приветствия
        state("/hello") {
            activators {
                // Отлавливаем различные варианты приветствий
                regex("привет", "здравствуй", "добрый день", "доброе утро", "добрый вечер", "хай", "hello", "hi", "приветствую", "здравствуйте")
            }
            action {
                reactions.say("Привет! Я ваш бот-помощник. Я могу рассказать о текущей погоде или актуальных курсах валют. Что вас интересует?")
            }
        }

        // Стейт запроса погоды
        state("/weather") {
            activators {
                // Отлавливаем различные формулировки запроса о погоде
                regex("погода", "прогноз погоды", "какая погода", "температура", "будет дождь", "узнай погоду", "прогноз", "сколько градусов")
            }
            action {
                reactions.say("Сегодня ожидается переменная облачность, температура воздуха +22°C. Осадков не предвидится, отличный день для прогулок!")
            }
        }

        // Стейт запроса курса валют
        state("/currency") {
            activators {
                // Отлавливаем различные формулировки запроса о валюте
                regex("курс валют", "курс доллара", "курс евро", "сколько стоит доллар", "сколько стоит евро", "валюты", "курс рубля", "обмен валют")
            }
            action {
                reactions.say("Актуальный курс на сегодня: 1 USD = 92.50 RUB, 1 EUR = 99.80 RUB. (Данные приведены для примера)")
            }
        }

        // Стейт обработки исключений (нераспознанные интенты)
        state("/NoMatch") {
            activators {
                // catchAll() перехватывает все запросы, которые не подошли ни под один из вышеуказанных стейтов
                catchAll()
            }
            action {
                reactions.say("Извините, я не понял ваш запрос. Попробуйте спросить: 'какая погода?', 'курс валют' или просто скажите 'привет'.")
            }
        }
    }
}